# ══════════════════════════════════════════════════════════════════════════════
#  Copy this file to .env and fill in the values.
#  .env is gitignored — never commit it.
# ══════════════════════════════════════════════════════════════════════════════


# ── Source DB (quest_rearch_production) ───────────────────────────────────────

# Bastion / jump server
SOURCE_SSH_HOST=ip_address
SOURCE_SSH_PORT=22
SOURCE_SSH_USER=username    
# Filename only — file must exist in ael_v2_pipeline/DB_Config/
SOURCE_SSH_PKEY_FILE=key.pem

# RDS endpoint (accessed through the tunnel)
SOURCE_RDS_HOST=host_source
SOURCE_RDS_PORT=port_number

# MySQL credentials
SOURCE_DB_USER=username
SOURCE_DB_PASSWORD=password
SOURCE_DB_NAME=database_name


# ── Destination DB (quest_ple_analytics) ──────────────────────────────────────

# Bastion / jump server
DEST_SSH_HOST=ip_address
DEST_SSH_PORT=22
DEST_SSH_USER=username
# Filename only — file must exist in ael_v2_pipeline/DB_Config/
DEST_SSH_PKEY_FILE=key.pem

# RDS endpoint (accessed through the tunnel)
DEST_RDS_HOST=destination_host
DEST_RDS_PORT=port_number

# MySQL credentials
DEST_DB_USER=username
DEST_DB_PASSWORD=password
DEST_DB_NAME=database_name


# ── Output ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=output


# ── Direct DB connection (no SSH tunnel) ──────────────────────────────────────
# Set DB_DIRECT=1 on a host with direct network access to the RDS endpoints
# (e.g. the server inside the VPC). pymysql then connects straight to
# SOURCE_RDS_HOST / DEST_RDS_HOST and skips SSH — faster, and each worker gets
# its own connection so allocation queries run truly in parallel.
# Leave 0 (or unset) on a laptop that must reach RDS through the bastion.
DB_DIRECT=0
